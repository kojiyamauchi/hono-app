PORT=3000
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"
# OpenAPI JSON(/open-api/doc)とScalar UI(/open-api/scalar)の公開フラグ。trueのときだけ登録する。staging/prodはfalseで非公開にする。
ENABLE_API_DOCS=false
JWT_SECRET="your-jwt-secret"
REFRESH_TOKEN_SECRET="your-refresh-token-secret"
# パスワードリセットトークンのHMAC-SHA256署名鍵。設定がないとパスワードリセットエンドポイントが500を返す。
PASSWORD_RESET_TOKEN_SECRET="your-password-reset-token-secret"
# Resend APIキー。パスワードリセットメール送信に使用する。https://resend.com でAPIキーを発行する。
RESEND_API_KEY="re_your_resend_api_key"
# パスワードリセットメールの送信元アドレス。Resendで検証済みのドメインを使用する。
PASSWORD_RESET_FROM_EMAIL="noreply@your-domain.com"
# フロントエンドのパスワード再設定ページURL。?token=... が付与されてメール本文のリセットURLになる。
PASSWORD_RESET_URL_BASE="https://your-frontend.com/reset-password"
SUPABASE_URL="http://127.0.0.1:54321"
SUPABASE_ANON_KEY="your-supabase-anon-key"
ALLOWED_ORIGINS="http://localhost:3000"
# リフレッシュトークンCookieのSecure属性。未設定なら有効（本番は必ず有効）。ローカルのHTTP開発でのみ false にする。
COOKIE_SECURE="false"
# リフレッシュトークンCookieのSameSite属性。既定はLax（same-site構成）。cross-site構成ではNoneにする（その場合Secureが必須となり自動的に有効化される）。
COOKIE_SAMESITE="Lax"
# OpenTelemetry trace送信の有効化フラグ。未設定またはfalseの場合はexporterを作らず外部送信しない。
OTEL_TRACES_ENABLED="false"
# OpenTelemetry SDK全体の無効化フラグ。trueの場合はOTEL_TRACES_ENABLED=trueでも初期化しない。
OTEL_SDK_DISABLED="false"
# New Relic上で表示するservice.name。
OTEL_SERVICE_NAME="hono-app"
# root traceのhead-based sampling ratio。0.1なら約10%を送信する。
OTEL_TRACES_SAMPLER_RATIO="0.1"
# New Relic OTLP/HTTP protobuf trace endpoint。
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT="https://otlp.nr-data.net:4318/v1/traces"
# New Relic license keyを含むtrace専用OTLP header。実値は.envやsecret managerで管理し、リポジトリへコミットしない。
OTEL_EXPORTER_OTLP_TRACES_HEADERS="api-key=your-new-relic-license-key"
