{
  "name": "hono-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "build": "tsc --noEmit",
    "lint": "eslint --fix --max-warnings 0",
    "format": "prettier --write .",
    "spellcheck": "cspell --dot --no-must-find-files '**/*'",
    "jest": "jest --passWithNoTests",
    "lint-staged": "lint-staged --allow-empty",
    "typecheck": "tsc --noEmit",
    "db:start": "npx supabase@2.101.0 start",
    "db:stop": "npx supabase@2.101.0 stop",
    "db:reset": "npx supabase@2.101.0 db reset",
    "db:status": "npx supabase@2.101.0 status",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:validate": "prisma validate",
    "prisma:format": "prisma format",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "hono": "^4.12.23",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/parser": "^8.41.0",
    "cspell": "^9.2.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "lint-staged": "^16.1.5",
    "prettier": "^3.6.2",
    "prisma": "^7.8.0",
    "ts-jest": "^29.4.11",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.41.0"
  }
}
